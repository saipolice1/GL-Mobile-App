{
  "expo": {
    "name": "Grafton Liquor",
    "slug": "grafton-liquor",
    "version": "1.0.18",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "graftonliquor",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "nz.co.graftonliquor.app",
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/adaptive-icon-background.png"
      },
      "versionCode": 17,
      "package": "nz.co.graftonliquor.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Grafton Liquor to use your location to show relevant delivery options and product availability in your area."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1B1B1B",
          "androidMode": "default",
          "androidCollapsedTitle": "Grafton Liquor"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Grafton Liquor to use Face ID for quick and secure login."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "grafton-liquor",
          "project": "gl-mobile-app"
        }
      ],
      "./plugins/withWebViewKeyboardFix",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Grafton Liquor to access your photos to set a profile picture.",
          "cameraPermission": "Allow Grafton Liquor to use your camera to take a profile picture."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ff7755f5-3855-4230-bf8d-7ec40561eed4"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ff7755f5-3855-4230-bf8d-7ec40561eed4"
    }
  }
}
